%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0a87e73e0b4de1046a0fbd021e8f538f, type: 3}
  m_Name: GameAudioManagerPreset
  m_EditorClassIdentifier: Assembly-CSharp::GameAudioManagerPreset
  presetId: 758fe216b5ad4bb49c133830e6682e5f
  presetName: GameAudioManagerPreset
  description: 
  version: 1.0.0
  playbackSettings:
    enabled: 1
    masterVolume: 1
    defaultMinimumDistance: 1
    defaultMaximumDistance: 45
    logMissingEventPaths: 1
  routingSettings:
    masterBusPath: bus:/
    sfxBusPath: bus:/SFX
    musicBusPath: bus:/Music
    sfxVolume: 1
    musicVolume: 1
  backgroundMusicSettings:
    enabled: 1
    eventPath: event:/MUSIC/mus_past
    bankName: BankMusic
    volume: 1
    autoStart: 1
    restartWhenPathChanges: 1
    stopWhenDisabled: 1
  eventBindings:
  - eventId: 1
    eventCode: MC_SFX_Shoot_Projectile_Player
    displayName: Player Projectile Shot
    description: Requested when the player emits one projectile shot batch.
    eventPath: event:/SFX/sfx_jump
    volume: 1
    pitch: 1
    spatialize: 0
    minimumDistance: 1
    maximumDistance: 45
    rateLimit:
      enabled: 0
      maxPlaysPerWindow: 1
      windowSeconds: 1
  - eventId: 2
    eventCode: MC_SFX_Shoot_Projectile_Enemy
    displayName: Enemy Projectile Shot
    description: Requested when an enemy shooter module emits projectiles; rate-limited
      by default.
    eventPath: event:/SFX/sfx_pickup
    volume: 1
    pitch: 1
    spatialize: 1
    minimumDistance: 1
    maximumDistance: 45
    rateLimit:
      enabled: 1
      maxPlaysPerWindow: 8
      windowSeconds: 0.25
  - eventId: 3
    eventCode: MC_SFX_Shoot_Laser_Continuous
