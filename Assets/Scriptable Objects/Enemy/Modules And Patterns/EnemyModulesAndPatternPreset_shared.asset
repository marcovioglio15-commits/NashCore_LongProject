  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a95fbd5918f4fd64c86fa231be2974c2, type: 3}
  m_Name: EnemyModulesAndPatternPreset_shared
  m_EditorClassIdentifier: Assembly-CSharp::EnemyModulesAndPatternsPreset
  presetId: 2aa588931bca463abfc5c594cc60e9d8
  presetName: EnemyModulesAndPatternPreset_shared
  description: 
  version: 1.0.0
  coreMovementDefinitions:
  - moduleId: Module_Stationary
    displayName: Stationary
    moduleKind: 0
    notes: Stops movement and can optionally freeze rotation.
    data:
      stationary:
        freezeRotation: 1
      wanderer:
        mode: 0
        basic:
          searchRadius: 9
          minimumTravelDistance: 2
          maximumTravelDistance: 8
          arrivalTolerance: 0.35
          waitCooldownSeconds: 0.7
          candidateSampleCount: 9
          useInfiniteDirectionSampling: 1
          infiniteDirectionStepDegrees: 8
          unexploredDirectionPreference: 0.65
          towardPlayerPreference: 0.35
          minimumEnemyClearance: 0.2
          trajectoryPredictionTime: 0.35
          freeTrajectoryPreference: 4
          blockedPathRetryDelay: 0.25
        dvd:
          speedMultiplier: 1.05
          bounceDamping: 1
          randomizeInitialDirection: 1
          fixedInitialDirectionDegrees: 45
          cornerNudgeDistance: 0.08
          ignoreSteeringAndPriority: 0
      coward:
        detectionRadius: 8
        releaseDistanceBuffer: 1.5
        searchRadius: 10
        minimumRetreatDistance: 2.5
        maximumRetreatDistance: 8.5
        arrivalTolerance: 0.35
        candidateSampleCount: 12
        useInfiniteDirectionSampling: 1
        infiniteDirectionStepDegrees: 8
        minimumEnemyClearance: 0.25
        trajectoryPredictionTime: 0.35
        freeTrajectoryPreference: 0.85
        retreatDirectionPreference: 0.65
        openSpacePreference: 0.55
        navigationRetreatPreference: 0.6
        patrolRadius: 3.5
        patrolWaitSeconds: 0.55
        patrolSpeedMultiplier: 0.82
        retreatSpeedMultiplierFar: 1
        retreatSpeedMultiplierNear: 1.4
        blockedPathRetryDelay: 0.2
      shortRangeDash:
        aim:
          aimDurationSeconds: 0.4
          moveSpeedMultiplierWhileAiming: 0.1
        recovery:
          cooldownSeconds: 1
        distance:
          distanceSource: 0
          playerDistanceMultiplier: 1
          distanceOffset: 0
          fixedDistance: 5
          minimumTravelDistance: 2
          maximumTravelDistance: 7
        path:
          dashDurationSeconds: 0.28
          lateralAmplitude: 1.2
          mirrorMode: 2
          forwardProgressCurve:
            serializedVersion: 2
            m_Curve:
            - serializedVersion: 3
              time: 0
              value: 0
              inSlope: 0
              outSlope: 0
              tangentMode: 0
              weightedMode: 0
              inWeight: 0
              outWeight: 0
            - serializedVersion: 3
              time: 1
              value: 1
              inSlope: 0
              outSlope: 0
              tangentMode: 0
              weightedMode: 0
              inWeight: 0
              outWeight: 0
            m_PreInfinity: 2
            m_PostInfinity: 2
            m_RotationOrder: 4
          lateralOffsetCurve:
            serializedVersion: 2
            m_Curve:
            - serializedVersion: 3
              time: 0
              value: 0
              inSlope: 0
              outSlope: 0
              tangentMode: 0
              weightedMode: 0
              inWeight: 0
              outWeight: 0
            - serializedVersion: 3
              time: 1
              value: 0
              inSlope: 0
              outSlope: 0
              tangentMode: 0
              weightedMode: 0
              inWeight: 0
              outWeight: 0
            m_PreInfinity: 2
            m_PostInfinity: 2
            m_RotationOrder: 4
      shooter:
        aimPolicy: 0
        movementPolicy: 0
        fireInterval: 1
        burstCount: 1
        aimWindupSeconds: 0.25
        intraBurstDelay: 0.08
        useMinimumRange: 0
        minimumRange: 2
        useMaximumRange: 0
        maximumRange: 20
        projectile:
          projectilesPerShot: 1
          spreadAngleDegrees: 0
          projectileSpeed: 14
          projectileDamage: 6
          projectileRange: 28
          projectileLifetime: 4
          projectileExplosionRadius: 0
          projectileScaleMultiplier: 1
          penetrationMode: 0
          maxPenetrations: 0
          inheritShooterSpeed: 0
        runtimeProjectile:
          projectilePrefab: {fileID: 0}
          poolInitialCapacity: 24
          poolExpandBatch: 8
        elemental:
          enableElementalDamage: 0
          effectData:
            elementType: 0
            effectKind: 0
            procMode: 0
            reapplyMode: 0
            procThresholdStacks: 5
            maximumStacks: 20
            stackDecayPerSecond: 1
            consumeStacksOnProc: 0
            dotDamagePerTick: 4
            dotTickInterval: 0.5
            dotDurationSeconds: 2
            impedimentSlowPercentPerStack: 10
            impedimentProcSlowPercent: 50
            impedimentMaxSlowPercent: 100
            impedimentDurationSeconds: 2
          stacksPerHit: 1
      dropItems:
        dropPayloadKind: 0
        experience:
          dropDefinitions: []
          complessiveExperienceDropMinimum: 10
          complessiveExperienceDropMaximum: 0
          dropsDistribution: 0.5
          dropRadius: 0.6
          collectionMovement:
            moveSpeed: 8
            collectDistance: 0.3
            collectDistancePerPlayerSpeed: 0.05
            spawnAnimationMinDuration: 0.08
            spawnAnimationMaxDuration: 0.16
