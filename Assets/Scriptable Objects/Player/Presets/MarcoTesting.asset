  scalingRules:
  - statKey: healthStatistics.maxHealth
    addScaling: 1
    formula: '[Health]'
    debugInConsole: 1
    debugColor: {r: 0.10173239, g: 1, b: 0.015686274, a: 1}
  - statKey: shootingSettings.values.shootSpeed
    addScaling: 0
    formula: '[this] + [FireRate]^2'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: shootingSettings.values.rateOfFire
    addScaling: 1
    formula: '[FireRate]'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.1254902, b: 0.015686275, a: 1}
  - statKey: movementSettings.values.baseSpeed
    addScaling: 1
    formula: '[MovementSpeed]'
    debugInConsole: 1
    debugColor: {r: 0.015686274, g: 0.81909794, b: 1, a: 1}
  - statKey: movementSettings.values.maxSpeed
    addScaling: 1
    formula: '[MovementSpeed] + 8'
    debugInConsole: 1
    debugColor: {r: 0.015686275, g: 0.8196079, b: 1, a: 1}
  - statKey: healthStatistics.maxShield
    addScaling: 1
    formula: '[Shield]'
    debugInConsole: 1
    debugColor: {r: 0.61235636, g: 0.015686274, b: 1, a: 1}
  - statKey: shootingSettings.values.damage
    addScaling: 1
    formula: '[this] * [Damage]'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.1254902, b: 0.015686275, a: 1}
  - statKey: shootingSettings.values.range
    addScaling: 1
    formula: '[this] * [ShotRange]'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.12460787, b: 0.015686274, a: 1}
  - statKey: shootingSettings.values.lifetime
    addScaling: 1
    formula: '[this] + [ShotRange]'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.1254902, b: 0.015686275, a: 1}
  - statKey: shootingSettings.values.maxPenetrations
    addScaling: 1
    formula: '[BulletPenetration]'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.1254902, b: 0.015686275, a: 1}
  - statKey: shootingSettings.values.projectileSizeMultiplier
    addScaling: 1
    formula: '[this] * [BulletSizeMultiplier]'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.1254902, b: 0.015686275, a: 1}
  - statKey: shootingSettings.values.explosionRadius
    addScaling: 1
    formula: '[this] * [BulletSizeMultiplier]'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.1254902, b: 0.015686275, a: 1}
  - statKey: shootingSettings.values.penetrationMode
    addScaling: 1
    formula: '[InfinitePenetration]?[Infinite]:[FixedHits]'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: 'shootingSettings.values.appliedElements.Array.data[0]'
    addScaling: 1
    formula: switch([BulletElementType_A],"Fire":[Fire],"Ice":[Ice],"Poison":[Poison],"None":[None],[None])
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
