  m_Script: {fileID: 11500000, guid: 10910fec561694a45ad2b09a5ad9bbba, type: 3}
  m_Name: PlayerPowerUpsPreset
  m_EditorClassIdentifier: Assembly-CSharp::PlayerPowerUpsPreset
  presetId: 780bde0072904df3a87793ed6799b56e
  presetName: PlayerPowerUpsPreset
  description: 
  version: 1.0.0
  primaryToolActionId: e0ab25f2-733a-4721-9b7a-2c8198b602da
  secondaryToolActionId: 348a94c1-2df4-48f8-82f6-83416ff0bd17
  dropPoolCatalog:
  - Milestone
  - Shop
  - Boss
  moduleDefinitions:
  - moduleId: module_trigger_press_standard
    displayName: Trigger Press
    moduleKind: 0
    defaultStage: 0
    notes: Fires when the input is initially pressed.
    data:
      holdCharge:
        requiredCharge: 500
        maximumCharge: 500
        chargeRatePerSecond: 125
      resourceGate:
        activationResource: 1
        maintenanceResource: 1
        maximumEnergy: 100
        activationCost: 100
        maintenanceCostPerSecond: 0
        fullChargeRequirement: 0
        chargeType: 0
        chargePerTrigger: 100
      cooldownGate:
        cooldownSeconds: 1
      suppressShooting:
        suppressBaseShootingWhileActive: 1
      projectilePatternCone:
        projectileCount: 6
        coneAngleDegrees: 45
      projectileScale:
        sizeMultiplier: 1
        damageMultiplier: 1
        speedMultiplier: 1
        rangeMultiplier: 1
        lifetimeMultiplier: 1
      projectilePenetration:
        mode: 0
        maxPenetrations: 0
      bomb:
        bombPrefab: {fileID: 0}
        spawnOffset: {x: 0, y: 0, z: 1.2}
        deploySpeed: 4.5
        collisionRadius: 0.18
        bounceOnWalls: 1
        bounceDamping: 0.65
        linearDampingPerSecond: 1.2
        fuseSeconds: 1.25
        radius: 7
        damage: 120
        affectAllEnemiesInRadius: 1
      dash:
        distance: 6
        duration: 0.18
        speedTransitionInSeconds: 0.06
        speedTransitionOutSeconds: 0.08
        grantsInvulnerability: 1
        invulnerabilityExtraTime: 0.1
      bulletTime:
        duration: 3
        enemySlowPercent: 40
      healMissingHealth:
        healAmount: 30
      deathExplosion:
        triggerMode: 0
        cooldownSeconds: 2
        radius: 4
        damage: 20
        affectAllEnemiesInRadius: 1
        triggerOffset: {x: 0, y: 0, z: 0}
        explosionVfxPrefab: {fileID: 0}
        scaleVfxToRadius: 1
        vfxScaleMultiplier: 1
      projectileOrbitOverride:
        radialEntrySpeed: 12
        orbitalSpeed: 8
        orbitRadiusMin: 4
        orbitRadiusMax: 6
        orbitPulseFrequency: 0.7
        orbitEntryRatio: 0.9
        orbitBlendDuration: 0.3
        heightOffset: 0
        goldenAngleDegrees: 137.5
      projectileBounceOnWalls:
        maxBounces: 2
        speedPercentChangePerBounce: -5
        minimumSpeedMultiplierAfterBounce: 0.1
        maximumSpeedMultiplierAfterBounce: 3
      projectileSplitOnDeath:
        directionMode: 0
        splitProjectileCount: 2
        splitOffsetDegrees: 0
        customAnglesDegrees:
        - -20
        - 20
        splitDamagePercentFromOriginal: 50
        splitSizePercentFromOriginal: 75
        splitSpeedPercentFromOriginal: 85
        splitLifetimePercentFromOriginal: 65
      trailSpawn:
        trailSegmentLifetimeSeconds: 1.5
        trailSpawnDistance: 0.6
        trailSpawnIntervalSeconds: 0.1
        trailRadius: 1.2
        maxActiveSegmentsPerPlayer: 30
        trailAttachedVfxOffset: {x: 0, y: 0.08, z: 0}
      elementalAreaTick:
        effectData:
          elementType: 0
          effectKind: 0
          procMode: 0
          reapplyMode: 0
          procThresholdStacks: 5
          maximumStacks: 20
          stackDecayPerSecond: 1
          consumeStacksOnProc: 0
          dotDamagePerTick: 4
          dotTickInterval: 0.5
          dotDurationSeconds: 2
          impedimentSlowPercentPerStack: 10
          impedimentProcSlowPercent: 50
          impedimentMaxSlowPercent: 100
          impedimentDurationSeconds: 2
        stacksPerTick: 1
        applyIntervalSeconds: 0.2
