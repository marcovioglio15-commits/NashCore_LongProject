  m_Script: {fileID: 11500000, guid: 10910fec561694a45ad2b09a5ad9bbba, type: 3}
  m_Name: PlayerPowerUpsPreset
  m_EditorClassIdentifier: Assembly-CSharp::PlayerPowerUpsPreset
  presetId: 780bde0072904df3a87793ed6799b56e
  presetName: PlayerPowerUpsPreset
  description: 
  version: 1.0.0
  scalingRules:
  - statKey: activePowerUps.Array.data[1|powerUpId:ActiveChargeShot].moduleBindings.Array.data[2|moduleId:Module_GateResource].overridePayload.resourceGate.cooldownSeconds
    addScaling: 0
    formula: 
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: moduleDefinitions.Array.data[2|moduleId:Module_TriggerHoldCharge].data.holdCharge.requiredCharge
    addScaling: 0
    formula: 
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: moduleDefinitions.Array.data[8|moduleId:Module_SpawnObject].data.bomb.radius
    addScaling: 0
    formula: '[this] + log([FireRate])'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.6046631, b: 0.015686274, a: 1}
  - statKey: moduleDefinitions.Array.data[9|moduleId:Module_Dash].data.dash.distance
    addScaling: 0
    formula: 
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: activePowerUps.Array.data[0|powerUpId:Active_Shotgun].moduleBindings.Array.data[2|moduleId:Module_ProjectilesPatternCone].overridePayload.projectilePatternCone.projectileCount
    addScaling: 1
    formula: '[ShotgunBarrels]*5'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: passivePowerUps.Array.data[7|powerUpId:Passive_AdditionalBarrel].moduleBindings.Array.data[1|moduleId:Module_ProjectilesPatternCone].overridePayload.projectilePatternCone.projectileCount
    addScaling: 1
    formula: '[ShotgunBarrels]'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: passivePowerUps.Array.data[7|powerUpId:Passive_AdditionalBarrel].moduleBindings.Array.data[1|moduleId:Module_ProjectilesPatternCone].overridePayload.projectilePatternCone.coneAngleDegrees
    addScaling: 1
    formula: '[ShotgunBarrels]*5'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: passivePowerUps.Array.data[7|powerUpId:Passive_AdditionalBarrel].moduleBindings.Array.data[2|moduleId:ModuleStackable].overridePayload.stackable.maxAcquisitions
    addScaling: 0
    formula: 
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: activePowerUps.Array.data[0|powerUpId:Active_Shotgun].moduleBindings.Array.data[2|moduleId:Module_ProjectilesPatternCone].overridePayload.projectilePatternCone.coneAngleDegrees
    addScaling: 1
    formula: '[ShotgunBarrels]*5*5'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: moduleDefinitions.Array.data[19|moduleId:Module_LaserBeam].data.laserBeam.bodyWidthMultiplier
    addScaling: 1
    formula: '[LaserWidth]'
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: moduleDefinitions.Array.data[19|moduleId:Module_LaserBeam].data.laserBeam.bodyProfile
    addScaling: 0
    formula: 
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  - statKey: moduleDefinitions.Array.data[19|moduleId:Module_LaserBeam].data.laserBeam.visualPresetId
    addScaling: 0
    formula: 
    debugInConsole: 0
    debugColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
